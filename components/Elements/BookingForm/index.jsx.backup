import { useRef, useState, useEffect } from 'react';
import { DateRange } from 'react-date-range';
import 'react-date-range/dist/styles.css';
import 'react-date-range/dist/theme/default.css';
import { FaCalendarAlt, FaUser, FaChild, FaDoorOpen, FaSearch } from 'react-icons/fa';

const BookingForm = ({ slug, adult, children, roomQuantity, setAdult, setChildren, setRoomQuantity, handleDateChange, range }) => {
    const [open, setOpen] = useState(false);

    const refOne = useRef(null);

    useEffect(() => {
        document.addEventListener('mousedown', handleClickOutside);
        return () => {
            document.removeEventListener('mousedown', handleClickOutside);
        };
    }, []);

    function handleClickOutside(e) {
        if (refOne.current && !refOne.current.contains(e.target)) {
            setOpen(false);
        }
    }

    const formatDate = (date) => {
        return date.toLocaleDateString('id-ID', {
            weekday: 'short',
            day: '2-digit',
            month: 'short',
            year: 'numeric',
        });
    };

    const handleSubmit = (e) => {
        e.preventDefault();
    };

    return (
        <div className='sticky top-0 z-50 bg-white shadow-xl border-b-4 border-blue-600'>
            <div className='max-w-7xl mx-auto'>
                <form onSubmit={handleSubmit} action={`/${slug}`} method='GET'>
                    {/* Main Grid */}
                    <div className='grid grid-cols-1 lg:grid-cols-12 divide-y lg:divide-y-0 lg:divide-x divide-blue-200'>
                        
                        {/* Date Selection */}
                        <div className='lg:col-span-4 p-4 relative' ref={refOne}>
                            <label className='block text-gray-700 text-xs font-bold uppercase tracking-wider mb-2'>
                                <FaCalendarAlt className='inline mr-2 text-blue-600' />
                                Check In
                            </label>
                            <input
                                type='text'
                                readOnly
                                value={formatDate(range[0].startDate)}
                                onClick={() => setOpen(!open)}
                                className='w-full p-3 bg-blue-50 border-2 border-blue-200 
                                           text-blue-900 font-bold cursor-pointer
                                           focus:outline-none focus:border-blue-600 focus:bg-white
                                           transition-all duration-200'
                            />
                            <input type='hidden' name='checkIn' value={range[0].startDate} />

                            {/* Calendar Dropdown */}
                            {open && (
                                <div className='absolute top-full left-0 z-50 mt-2 shadow-2xl border-2 border-blue-600 bg-white'>
                                    <DateRange
                                        editableDateInputs={true}
                                        onChange={handleDateChange}
                                        moveRangeOnFirstSelection={false}
                                        ranges={range}
                                        months={2}
                                        direction='horizontal'
                                        minDate={new Date()}
                                    />
                                </div>
                            )}
                        </div>

                        {/* Check Out */}
                        <div className='lg:col-span-3 p-4'>
                            <label className='block text-gray-700 text-xs font-bold uppercase tracking-wider mb-2'>
                                <FaCalendarAlt className='inline mr-2 text-blue-600' />
                                Check Out
                            </label>
                            <input
                                type='text'
                                readOnly
                                value={formatDate(range[0].endDate)}
                                onClick={() => setOpen(!open)}
                                className='w-full p-3 bg-blue-50 border-2 border-blue-200 
                                           text-blue-900 font-bold cursor-pointer
                                           focus:outline-none focus:border-blue-600 focus:bg-white
                                           transition-all duration-200'
                            />
                            <input type='hidden' name='checkOut' value={range[0].endDate} />
                        </div>

                        {/* Guests */}
                        <div className='lg:col-span-2 p-4'>
                            <label className='block text-gray-700 text-xs font-bold uppercase tracking-wider mb-3'>
                                <FaUser className='inline mr-2 text-blue-600' />
                                Tamu
                            </label>
                            <div className='space-y-2'>
                                <div className='flex items-center justify-between'>
                                    <span className='text-sm font-bold text-gray-700'>Dewasa</span>
                                    <div className='flex items-center gap-1'>
                                        <button
                                            type='button'
                                            onClick={() => setAdult(Math.max(1, adult - 1))}
                                            className='w-7 h-7 bg-gray-200 hover:bg-blue-600 hover:text-white font-bold transition-all'>
                                            -
                                        </button>
                                        <span className='w-8 text-center font-bold text-gray-900'>{adult}</span>
                                        <button
                                            type='button'
                                            onClick={() => setAdult(Math.min(10, adult + 1))}
                                            className='w-7 h-7 bg-gray-200 hover:bg-blue-600 hover:text-white font-bold transition-all'>
                                            +
                                        </button>
                                    </div>
                                </div>
                                <div className='flex items-center justify-between'>
                                    <span className='text-sm font-bold text-gray-700'>Anak</span>
                                    <div className='flex items-center gap-1'>
                                        <button
                                            type='button'
                                            onClick={() => setChildren(Math.max(0, children - 1))}
                                            className='w-7 h-7 bg-gray-200 hover:bg-blue-600 hover:text-white font-bold transition-all'>
                                            -
                                        </button>
                                        <span className='w-8 text-center font-bold text-gray-900'>{children}</span>
                                        <button
                                            type='button'
                                            onClick={() => setChildren(Math.min(10, children + 1))}
                                            className='w-7 h-7 bg-gray-200 hover:bg-blue-600 hover:text-white font-bold transition-all'>
                                            +
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {/* Rooms & Submit */}
                        <div className='lg:col-span-3 p-4'>
                            <label className='block text-gray-700 text-xs font-bold uppercase tracking-wider mb-3'>
                                <FaDoorOpen className='inline mr-2 text-blue-600' />
                                Kamar
                            </label>
                            <div className='flex items-center justify-between mb-3'>
                                <span className='text-sm font-bold text-gray-700'>Jumlah</span>
                                <div className='flex items-center gap-1'>
                                    <button
                                        type='button'
                                        onClick={() => setRoomQuantity(Math.max(1, roomQuantity - 1))}
                                        className='w-7 h-7 bg-gray-200 hover:bg-blue-600 hover:text-white font-bold transition-all'>
                                        -
                                    </button>
                                    <span className='w-8 text-center font-bold text-gray-900'>{roomQuantity}</span>
                                    <button
                                        type='button'
                                        onClick={() => setRoomQuantity(Math.min(10, roomQuantity + 1))}
                                        className='w-7 h-7 bg-gray-200 hover:bg-blue-600 hover:text-white font-bold transition-all'>
                                        +
                                    </button>
                                </div>
                            </div>
                            
                            {/* Submit Button */}
                            <button
                                type='submit'
                                className='w-full bg-blue-600 hover:bg-blue-700 text-white py-3 font-black uppercase tracking-wider
                                           transition-all duration-200 flex items-center justify-center gap-2 border-2 border-blue-700'>
                                <FaSearch />
                                Cari
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    );
};

export default BookingForm;
